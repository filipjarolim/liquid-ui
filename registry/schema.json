{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "GlassUI components.json",
	"type": "object",
	"properties": {
		"$schema": { "type": "string" },
		"style": { "type": "string", "enum": ["default"] },
		"framework": {
			"type": "string",
			"enum": ["react", "vue", "svelte", "angular", "vanilla", "next", "vite", "astro"]
		},
		"rsc": { "type": "boolean" },
		"tsx": { "type": "boolean" },
		"tailwind": {
			"type": "object",
			"properties": {
				"config": { "type": "string" },
				"css": { "type": "string" },
				"baseColor": { "type": "string" },
				"cssVariables": { "type": "boolean" }
			},
			"required": ["css", "cssVariables"]
		},
		"aliases": {
			"type": "object",
			"properties": {
				"components": { "type": "string" },
				"utils": { "type": "string" },
				"glass": { "type": "string" },
				"lib": { "type": "string" },
				"hooks": { "type": "string" }
			},
			"required": ["components", "utils", "glass"]
		}
	},
	"required": ["style", "tailwind", "aliases"]
}
