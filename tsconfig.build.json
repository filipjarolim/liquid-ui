{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"incremental": false,
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"outDir": "dist",
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "bundler"
	},
	"include": ["src/index.ts", "src/elements.ts", "src/react.ts", "src/**/*.ts"],
	"exclude": ["src/app", "node_modules", ".next"]
}
